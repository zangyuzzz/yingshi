6f\u0020\u004e\u0061\u006b\u0061\u006d\u0075\u0072\u0061\u0029\u000a










\u005b\u0030\u0030\u003a\u0030\u0030\u002e\u0030\u0030\u0030\u005d\u0020\u4f5c\u8bcd\u0020\u003a\u0020\u7c73\u679c\u000a\u005b\u0030\u0030\u003a\u0030\u0031\u002e\u0030\u0030\u0030\u005d\u0020\u4f5c\u66f2\u0020\u003a\u0020\u9ad8\u6a4b\u512a\u000a\u005b\u0030\u0030\u003a\u0030\u0032\u002e\u0030\u0030\u0030\u005d\u0020\u7f16\u66f2\u0020\u003a\u0020\u6c60\u7aaa\u6d69\u4e00\u0020\u0028\u004b\u006f\u0075\u0069\u0063\u0068\u0069\u0020\u0049\u006b\u0065\u006b\u0075\u0062\u006f\u0029\u000a\u005b\u0030\u0030\u003a\u0032\u0035\u002e\u0032\u0033\u0037\u005d\u8fd9\u4e00\u8def\u4e0a\u8d70\u8d70\u505c\u505c\u000a\u005b\u0030\u0030\u003a\u0032\u0038\u002e\u0035\u0039\u0032\u005d\u987a\u7740\u5c11\u5e74\u6f02\u6d41\u7684\u75d5\u8ff9\u000a\u005b\u0030\u0030\u003a\u0033\u0031\u002e\u0036\u0038\u0031\u005d\u8fc8\u51fa\u8f66\u7ad9\u7684\u524d\u4e00\u523b\u000a\u005b\u0030\u0030\u003a\u0033\u0034\u002e\u0037\u0039\u0035\u005d\u7adf\u6709\u4e9b\u72b9\u8c6b\u000a\u005b\u0030\u0030\u003a\u0033\u0037\u002e\u0037\u0039\u0034\u005d\u4e0d\u7981\u7b11\u8fd9\u8fd1\u4e61\u60c5\u602f\u000a\u005b\u0030\u0030\u003a\u0034\u0031\u002e\u0031\u0039\u0031\u005d\u4ecd\u65e0\u53ef\u907f\u514d\u000a\u005b\u0030\u0030\u003a\u0034\u0033\u002e\u0038\u0031\u0039\u005d\u800c\u957f\u91ce\u7684\u5929\u000a\u005b\u0030\u0030\u003a\u0034\u0035\u002e\u0031\u0033\u0034\u005d\u4f9d\u65e7\u90a3\u4e48\u6696\u000a\u005b\u0030\u0030\u003a\u0034\u0036\u002e\u0036\u0038\u0034\u005d\u98ce\u5439\u8d77\u4e86\u4ece\u524d\u000a\u005b\u0030\u0030\u003a\u0034\u0039\u002e\u0031\u0035\u0033\u005d\u4ece\u524d\u521d\u8bc6\u8fd9\u4e16\u95f4\u000a\u005b\u0030\u0030\u003a\u0035\u0032\u002e\u0031\u0038\u0035\u005d\u4e07\u822c\u6d41\u8fde\u000a\u005b\u0030\u0030\u003a\u0035\u0033\u002e\u0039\u0036\u0032\u005d\u770b\u7740\u5929\u8fb9\u4f3c\u5728\u773c\u524d\u000a\u005b\u0030\u0030\u003a\u0035\u0036\u002e\u0037\u0039\u0038\u005d\u4e5f\u7518\u613f\u8d74\u6c64\u8e48\u706b\u53bb\u8d70\u5b83\u4e00\u904d\u000a\u005b\u0030\u0031\u003a\u0030\u0031\u